# =============================================================================
# UPI RAG Chatbot - backend environment (Slice 1)
# Copy to `.env` and adjust. The app boots with these defaults; RAG endpoints
# stay 503 until the FAISS paths point at real index artefacts.
# =============================================================================

# --- App ---
APP_NAME=UPI RAG Chatbot API
APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api

# --- CORS: the Next.js frontend origin(s), comma-separated ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- RAG vector store ---------------------------------------------------------
# Point these at the artefacts produced by 03_vectorstore_rag_evaluation.ipynb.
# That notebook writes them to  _pipeline/index/  on Google Drive:
#   faiss.index, chunks_meta.json, index_info.json
# Download that folder and set the paths below (absolute paths are fine).
FAISS_INDEX_PATH=./app/data/faiss.index
CHUNKS_META_PATH=./app/data/chunks_meta.json
INDEX_INFO_PATH=./app/data/index_info.json

# --- Embeddings ---
# MUST match the model recorded in index_info.json, or retrieval degrades.
EMBEDDING_MODEL=intfloat/multilingual-e5-base
USE_E5_PREFIXES=true
EMBEDDING_BATCH_SIZE=32

# --- Retrieval ---
DEFAULT_TOP_K=5
MAX_TOP_K=20
RETRIEVAL_SCORE_THRESHOLD=0.0

# --- LLM backend: extractive | ollama | openai -------------------------------
# "extractive" needs no LLM and always works - good for first run and demos.
LLM_BACKEND=extractive
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_REQUEST_TIMEOUT=45

# Ollama (only used when LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Context window. Ollama defaults to 2048 which truncates RAG sources; 8192 is safe.
OLLAMA_NUM_CTX=8192

# OpenAI-compatible API (only used when LLM_BACKEND=openai)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Limits ---
MAX_QUERY_CHARS=2000
