# =============================================================================
# UPI RAG Chatbot - frontend environment
# Copy to `.env.local` and adjust.
# =============================================================================

# Public base URL the browser uses to reach the backend.
# Leave as the dev proxy path (recommended for local development): the Next.js
# rewrite in next.config.mjs forwards /backend-api/* to BACKEND_ORIGIN, avoiding
# CORS entirely during development.
NEXT_PUBLIC_API_BASE_URL=/backend-api

# For a direct (non-proxied) connection instead, set the full backend URL:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# The origin the dev proxy forwards to (server-side only; used by the rewrite).
BACKEND_ORIGIN=http://localhost:8000
